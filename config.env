CONFIG_ENV=config.env
KERNEL_SOURCE=https://github.com/denis344xui-bot/dreamlte
KERNEL_SOURCE_BRANCH=tw90-android
KERNEL_CONFIG=exynos8895-dreamlte_defconfig
ARCH=arm64
KERNEL_IMAGE_NAME=Image
ADD_LOCALVERSION_TO_FILENAME=false
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true
CLANG_VERSION=r416183b
CLANG_BRANCH=master-kernel-build-2021
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true
APPLY_KSU_PATCH=false
DISABLE_CC_WERROR=true
DISABLE-LTO=false
EXTRA_CMDS: CLANG_TRIPLE=aarch64-linux-gnu- HOSTCFLAGS=-fcommon KCFLAGS="-fcommon -Wno-error"
BUILD_BOOT_IMG=true
SOURCE_BOOT_IMAGE=https://github.com/denis344xui-bot/KernelSU_Action/releases/download/boot/boot.img
