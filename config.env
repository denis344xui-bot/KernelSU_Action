# KernelSU Action - S8 (dreamlte) config
# Fork https://github.com/xiaoleGun/KernelSU_Action e substitua config.env

# Kernel Source (Samsung SM-G950F open source)
# Baixe de https://opensource.samsung.com e faça upload pro seu GitHub
KERNEL_SOURCE=https://github.com/denis344xui-bot/sm-g950f-kernel
KERNEL_SOURCE_BRANCH=main

# Kernel config
KERNEL_CONFIG=exynos8895-dreamlte_defconfig
ARCH=arm64
KERNEL_IMAGE_NAME=Image

# Clang version (12 works for 4.4 kernel)
CLANG_VERSION=12.0.5

# Enable KernelSU (non-GKI, use v0.9.5)
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5

# Critical for S8 kernel 4.4
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true
APPLY_KERNELSU_PATCH=true
DISABLE_CC_WERROR=true

# Build boot.img
BUILD_BOOT_IMG=true
# URL to your stock boot.img (upload to GitHub raw)
SOURCE_BOOT_IMAGE=https://raw.githubusercontent.com/denis344xui-bot/sm-g950f-kernel/main/boot.img

# AnyKernel3 for TWRP flash
ENABLE_ANY_KERNEL3=true
