KERNEL_SOURCE=https://github.com/exynos-linux-stable/dreamlte
KERNEL_SOURCE_BRANCH=main
KERNEL_CONFIG=exynos8895-dreamlte_defconfig
ARCH=arm64
KERNEL_IMAGE_NAME=Image
ENABLE_GCC_64=true
ENABLE_GCC_32=true
CLANG_VERSION=12.0.5
CLANG_BRANCH=master
CUSTOM_CLANG_SOURCE=https://android.googlesource.com/platform/prebuilts/clang/host/linux-x86
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true
APPLY_KERNELSU_PATCH=true
DISABLE_CC_WERROR=true
BUILD_BOOT_IMG=true
SOURCE_BOOT_IMAGE=https://github.com/denis344xui-bot/KernelSU_Action/releases/download/boot/boot.img
